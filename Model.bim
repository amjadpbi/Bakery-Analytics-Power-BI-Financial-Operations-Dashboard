        "partitions": [
          {
            "name": "FactSalesLine",
            "mode": "import",
            "queryGroup": "9_Fact Tables",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = stgSales_Combined,",
                "",
                "    #\"Added LineAmount\" =",
                "        Table.AddColumn(",
                "            Source,",
                "            \"LineAmount\",",
                "            each [Quantity] * [UnitPrice],",
                "            Currency.Type",
                "        ),",
                "",
                "    #\"Added NetLineAmount\" =",
                "        Table.AddColumn(",
                "            #\"Added LineAmount\",",
                "            \"NetLineAmount\",",
                "            each ([Quantity] * [UnitPrice]) - [Discount] + [Tax],",
                "            Currency.Type",
                "        ),",
                "",
                "    Grouped =",
                "        Table.Group(",
                "            #\"Added NetLineAmount\",",
                "            {\"OrderID\"},",
                "            {",
                "                {",
                "                    \"Data\",",
                "                    (t as table) =>",
                "                        Table.AddIndexColumn(t, \"LineNumber\", 1, 1, Int64.Type),",
                "                    type table",
                "                }",
                "            }",
                "        ),",
                "",
                "    Expanded =",
                "    Table.ExpandTableColumn(",
                "        Grouped,",
                "        \"Data\",",
                "        List.RemoveItems(",
                "            Table.ColumnNames(#\"Added NetLineAmount\"),",
                "            {\"OrderID\"}",
                "        ) & {\"LineNumber\"}",
                "    ),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(Expanded,{{\"NetLineAmount\", Currency.Type}, {\"LineAmount\", Currency.Type}, {\"Tax\", Currency.Type}, {\"Discount\", Currency.Type}, {\"UnitPrice\", Currency.Type}, {\"Quantity\", Int64.Type}}),",
                "    #\"Removed Columns\" = Table.RemoveColumns(#\"Changed Type\",{\"Name\"}),",
                "    #\"Merged Queries\" = Table.NestedJoin(#\"Removed Columns\", {\"OrderID\"}, FactSalesHeader, {\"OrderID\"}, \"FactSalesHeader\", JoinKind.LeftOuter),",
                "    #\"Expanded FactSalesHeader\" = Table.ExpandTableColumn(#\"Merged Queries\", \"FactSalesHeader\", {\"SalesHeaderKey\"}, {\"SalesHeaderKey\"}),",
                "    #\"Reordered Columns\" = Table.ReorderColumns(#\"Expanded FactSalesHeader\",{\"SalesHeaderKey\", \"OrderID\", \"CustomerID\", \"ProductID\", \"OrderDate\", \"Quantity\", \"UnitPrice\", \"Discount\", \"Tax\", \"PaymentMethod\", \"Location\", \"LeadTime\", \"OrderStatus\", \"LineAmount\", \"NetLineAmount\", \"LineNumber\"}),",
                "    #\"Merged Queries1\" = Table.NestedJoin(#\"Reordered Columns\", {\"CustomerID\"}, DimCustomer, {\"CustomerID\"}, \"DimCustomer\", JoinKind.LeftOuter),",
                "    #\"Expanded DimCustomer\" = Table.ExpandTableColumn(#\"Merged Queries1\", \"DimCustomer\", {\"CustomerKey\"}, {\"CustomerKey\"}),",
                "    #\"Reordered Columns1\" = Table.ReorderColumns(#\"Expanded DimCustomer\",{\"SalesHeaderKey\", \"OrderID\", \"CustomerKey\", \"CustomerID\", \"ProductID\", \"OrderDate\", \"Quantity\", \"UnitPrice\", \"Discount\", \"Tax\", \"PaymentMethod\", \"Location\", \"LeadTime\", \"OrderStatus\", \"LineAmount\", \"NetLineAmount\", \"LineNumber\"}),",
                "    #\"Removed Columns1\" = Table.RemoveColumns(#\"Reordered Columns1\",{\"CustomerID\"}),",
                "    #\"Merged Queries2\" = Table.NestedJoin(#\"Removed Columns1\", {\"ProductID\"}, DimProduct, {\"ProductID\"}, \"DimProduct\", JoinKind.LeftOuter),",
                "    #\"Expanded DimProduct\" = Table.ExpandTableColumn(#\"Merged Queries2\", \"DimProduct\", {\"ProductKey\"}, {\"ProductKey\"}),",
                "    #\"Reordered Columns2\" = Table.ReorderColumns(#\"Expanded DimProduct\",{\"SalesHeaderKey\", \"OrderID\", \"CustomerKey\", \"ProductID\", \"ProductKey\", \"OrderDate\", \"Quantity\", \"UnitPrice\", \"Discount\", \"Tax\", \"PaymentMethod\", \"Location\", \"LeadTime\", \"OrderStatus\", \"LineAmount\", \"NetLineAmount\", \"LineNumber\"}),",
                "    #\"Removed Columns2\" = Table.RemoveColumns(#\"Reordered Columns2\",{\"ProductID\"}),",
                "    #\"Merged Queries3\" = Table.NestedJoin(#\"Removed Columns2\", {\"OrderDate\"}, DimDate, {\"Date\"}, \"DimDate\", JoinKind.LeftOuter),",
                "    #\"Expanded DimDate\" = Table.ExpandTableColumn(#\"Merged Queries3\", \"DimDate\", {\"DateKey\"}, {\"DateKey\"}),",
                "    #\"Reordered Columns3\" = Table.ReorderColumns(#\"Expanded DimDate\",{\"SalesHeaderKey\", \"OrderID\", \"DateKey\", \"ProductKey\", \"CustomerKey\", \"OrderDate\", \"Quantity\", \"UnitPrice\", \"Discount\", \"Tax\", \"PaymentMethod\", \"LineNumber\", \"Location\", \"LeadTime\", \"OrderStatus\", \"LineAmount\", \"NetLineAmount\"}),",
                "    #\"Removed Columns3\" = Table.RemoveColumns(#\"Reordered Columns3\",{\"CustomerKey\", \"OrderDate\", \"PaymentMethod\", \"LineNumber\", \"Location\", \"LeadTime\", \"OrderStatus\", \"OrderID\"})",
                "in",
                "    #\"Removed Columns3\""
              ]
            }
          }
        ],
        "annotations": [
