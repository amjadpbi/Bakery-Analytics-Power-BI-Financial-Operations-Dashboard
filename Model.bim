                "    #\"Removed Columns1\" = Table.RemoveColumns(#\"Reordered Columns3\",{\"Location\"}),",
                "    #\"Sorted Rows\" = Table.Sort(#\"Removed Columns1\",{{\"SalesHeaderKey\", Order.Ascending}}),",
