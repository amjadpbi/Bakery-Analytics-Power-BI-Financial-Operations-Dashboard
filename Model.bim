        "partitions": [
          {
            "name": "DimDate",
            "mode": "import",
            "queryGroup": "08_Dimension Tables",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = let",
                "    // Define date range",
                "    StartDate = #date(2022, 1, 1),",
                "    EndDate = #date(2024, 12, 31),",
                "    ",
                "    // Calculate number of days",
                "    DayCount = Duration.Days(EndDate - StartDate) + 1,",
                "    ",
                "    // Generate list of dates",
                "    DateList = List.Dates(StartDate, DayCount, #duration(1,0,0,0)),",
                "    ",
                "    // Convert to table",
                "    TableFromList = Table.FromList(DateList, Splitter.SplitByNothing()),",
                "    RenamedColumns = Table.RenameColumns(TableFromList,{{\"Column1\", \"Date\"}}),",
                "    ChangedType = Table.TransformColumnTypes(RenamedColumns,{{\"Date\", type date}}),",
                "    ",
                "    // Add DateKey",
                "    AddDateKey = Table.AddColumn(ChangedType, \"DateKey\", each ",
                "        Date.Year([Date]) * 10000 + Date.Month([Date]) * 100 + Date.Day([Date]), ",
                "        Int64.Type),",
                "    ",
                "    // Add Year, Quarter, Month",
                "    AddYear = Table.AddColumn(AddDateKey, \"Year\", each Date.Year([Date]), Int64.Type),",
                "    AddQuarter = Table.AddColumn(AddYear, \"Quarter\", each Date.QuarterOfYear([Date]), Int64.Type),",
                "    AddMonth = Table.AddColumn(AddQuarter, \"Month\", each Date.Month([Date]), Int64.Type),",
                "    AddWeek = Table.AddColumn(AddMonth, \"Week\", each Date.WeekOfYear([Date]), Int64.Type),",
                "    ",
                "    // Add Month and Day Names",
                "    AddMonthName = Table.AddColumn(AddWeek, \"MonthName\", each Date.MonthName([Date]), type text),",
                "    AddMonthShort = Table.AddColumn(AddMonthName, \"MonthShort\", each Text.Start([MonthName], 3), type text),",
                "    AddDayName = Table.AddColumn(AddMonthShort, \"DayName\", each Date.DayOfWeekName([Date]), type text),",
                "    AddDayShort = Table.AddColumn(AddDayName, \"DayShort\", each Text.Start([DayName], 3), type text),",
                "    ",
                "    // Add Day Numbers",
                "    AddDayOfWeek = Table.AddColumn(AddDayShort, \"DayOfWeek\", each ",
                "        Date.DayOfWeek([Date], Day.Monday) + 1, Int64.Type),",
                "    AddDayOfMonth = Table.AddColumn(AddDayOfWeek, \"DayOfMonth\", each Date.Day([Date]), Int64.Type),",
                "    AddDayOfYear = Table.AddColumn(AddDayOfMonth, \"DayOfYear\", each Date.DayOfYear([Date]), Int64.Type),",
                "    ",
                "    // Add IsWeekend",
                "    AddIsWeekend = Table.AddColumn(AddDayOfYear, \"IsWeekend\", each ",
                "        [DayOfWeek] >= 6, type logical),",
                "    ",
                "    // Add Fiscal Year (starts July 1)",
                "    AddFiscalYear = Table.AddColumn(AddIsWeekend, \"FiscalYear\", each ",
                "        if [Month] >= 7 then [Year] + 1 else [Year], Int64.Type),",
                "    ",
                "    AddFiscalQuarter = Table.AddColumn(AddFiscalYear, \"FiscalQuarter\", each ",
                "        if [Month] >= 7 and [Month] <= 9 then 1",
                "        else if [Month] >= 10 and [Month] <= 12 then 2",
                "        else if [Month] >= 1 and [Month] <= 3 then 3",
                "        else 4, Int64.Type),",
                "    ",
                "    // Add YearMonth for sorting",
                "    AddYearMonth = Table.AddColumn(AddFiscalQuarter, \"YearMonth\", each ",
                "        Text.From([Year]) & \"-\" & Text.PadStart(Text.From([Month]), 2, \"0\"), type text),",
                "    ",
                "    AddYearMonthNum = Table.AddColumn(AddYearMonth, \"YearMonthNum\", each ",
                "        [Year] * 100 + [Month], Int64.Type)",
                "in",
                "    AddYearMonthNum",
                "in",
                "    Source"
              ]
            }
          }
        ],
        "annotations": [
          {
            "name": "PBI_NavigationStepName",
            "value": "Navigation"
          },
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
