              "expression": [
                "let",
                "    Source = #table(",
                "        {\"PaymentMethodKey\", \"PaymentMethod\", \"ProcessingFeeRate\", \"IsActive\"},",
                "        {",
                "            {1, \"Cash\", 0.00, \"Yes\"},",
                "            {2, \"Credit Card\", 0.025, \"Yes\"},",
                "            {3, \"AfterPay\", 0.025, \"Yes\"},",
                "            {4, \"Shopify\", 0.029, \"Yes\"},",
                "            {5, \"On Account\", 0.00, \"Yes\"},",
                "            {-1, \"Unknown\", 0.00, \"No\"}",
                "        }",
                "    ),",
                "",
                "    #\"Changed Type\" = Table.TransformColumnTypes(Source,{{\"PaymentMethodKey\", Int64.Type}, {\"PaymentMethod\", type text}, {\"ProcessingFeeRate\", Currency.Type}, {\"IsActive\", type text}})",
                "in",
                "    #\"Changed Type\""
