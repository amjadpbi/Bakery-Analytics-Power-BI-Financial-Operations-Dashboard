            "name": "DimLocation",
            "mode": "import",
            "queryGroup": "08_Dimension Tables",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = stgSales_Combined,",
                "",
                "    #\"Removed Columns\" = Table.RemoveColumns(",
                "        Source,",
                "        {\"Name\",\"OrderID\",\"CustomerID\",\"ProductID\",\"OrderDate\",\"Quantity\",\"UnitPrice\",\"Discount\",\"Tax\",\"PaymentMethod\",\"LeadTime\",\"OrderStatus\"}",
                "    ),",
                "",
                "    #\"Removed Duplicates\" = Table.Distinct(#\"Removed Columns\"),",
                "",
                "    #\"Added Index\" = Table.AddIndexColumn(#\"Removed Duplicates\", \"Index\", 1, 1, Int64.Type),",
                "",
                "    #\"Reordered Columns\" = Table.ReorderColumns(#\"Added Index\",{\"Index\",\"Location\"}),",
                "",
                "    #\"Renamed Columns\" = Table.RenameColumns(#\"Reordered Columns\",{{\"Index\",\"LocationKey\"}}),",
                "",
                "    // Add Unknown row",
                "    UnknownRow = #table(",
                "        {\"LocationKey\",\"Location\"},",
                "        {{-1,\"Unknown\"}}",
                "    ),",
                "",
                "    // Combine with existing table",
                "    Combined = Table.Combine({UnknownRow, #\"Renamed Columns\"})",
                "in",
                "    Combined"
              ]
            }
          }
        ],
