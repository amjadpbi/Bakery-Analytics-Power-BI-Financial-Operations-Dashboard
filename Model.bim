        "partitions": [
          {
            "name": "FactSalesHeader",
            "mode": "import",
            "queryGroup": "9_Fact Tables",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = stgSales_Combined,",
                "    #\"Added Custom\" = Table.AddColumn(Source, \"LineAmount\", each [Quantity] * [UnitPrice]),",
                "    #\"Added Custom1\" = Table.AddColumn(#\"Added Custom\", \"NetLineAmount\", each ([Quantity] * [UnitPrice]) - [Discount] + [Tax]),",
                "  Grouped =",
                "    Table.Group(",
                "        (#\"Added Custom1\"),",
                "        {\"OrderID\"},",
                "        {",
                "            {\"CustomerID\", each List.First([CustomerID]), type text},",
                "            {\"OrderDate\", each List.First([OrderDate]), type date},",
                "            {\"Location\", each List.First([Location]), type text},",
                "            {\"OrderStatus\", each List.First([OrderStatus]), type text},",
                "            {\"LeadTime\", each List.First([LeadTime]), Int64.Type},",
                "            {\"PaymentMethod\", each List.First([PaymentMethod]), Int64.Type},",
                "            {\"TotalQuantity\", each List.Sum([Quantity]), Int64.Type},",
                "            {\"GrossAmount\", each List.Sum([LineAmount]), type number},",
                "            {\"TotalDiscount\", each List.Sum([Discount]), type number},",
                "            {\"TotalTax\", each List.Sum([Tax]), type number},",
                "            {\"NetAmount\", each List.Sum([NetLineAmount]), type number}",
                "        }",
                "    ),",
                "    #\"Added Index\" = Table.AddIndexColumn(Grouped, \"Index\", 1, 1, Int64.Type),",
                "    #\"Renamed Columns\" = Table.RenameColumns(#\"Added Index\",{{\"Index\", \"SalesHeaderKey\"}}),",
                "    #\"Reordered Columns\" = Table.ReorderColumns(#\"Renamed Columns\",{\"SalesHeaderKey\", \"OrderID\", \"CustomerID\", \"OrderDate\", \"Location\", \"OrderStatus\", \"LeadTime\", \"TotalQuantity\", \"GrossAmount\", \"TotalDiscount\", \"TotalTax\", \"NetAmount\"}),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(#\"Reordered Columns\",{{\"NetAmount\", Currency.Type}, {\"TotalTax\", Currency.Type}, {\"TotalDiscount\", Currency.Type}, {\"GrossAmount\", Currency.Type}}),",
                "    #\"Merged Queries\" = Table.NestedJoin(#\"Changed Type\", {\"CustomerID\"}, DimCustomer, {\"CustomerID\"}, \"DimCustomer\", JoinKind.LeftOuter),",
                "    #\"Expanded DimCustomer\" = Table.ExpandTableColumn(#\"Merged Queries\", \"DimCustomer\", {\"CustomerKey\"}, {\"DimCustomer.CustomerKey\"}),",
                "    #\"Renamed Columns1\" = Table.RenameColumns(#\"Expanded DimCustomer\",{{\"DimCustomer.CustomerKey\", \"CustomerKey\"}}),",
                "    #\"Reordered Columns1\" = Table.ReorderColumns(#\"Renamed Columns1\",{\"SalesHeaderKey\", \"OrderID\", \"CustomerKey\", \"CustomerID\", \"OrderDate\", \"Location\", \"OrderStatus\", \"LeadTime\", \"TotalQuantity\", \"GrossAmount\", \"TotalDiscount\", \"TotalTax\", \"NetAmount\"}),",
                "    #\"Removed Columns\" = Table.RemoveColumns(#\"Reordered Columns1\",{\"CustomerID\"}),",
                "    #\"Merged Queries1\" = Table.NestedJoin(#\"Removed Columns\", {\"OrderDate\"}, DimDate, {\"Date\"}, \"DimDate\", JoinKind.LeftOuter),",
                "    #\"Expanded DimDate\" = Table.ExpandTableColumn(#\"Merged Queries1\", \"DimDate\", {\"DateKey\"}, {\"DimDate.DateKey\"}),",
                "    #\"Renamed Columns2\" = Table.RenameColumns(#\"Expanded DimDate\",{{\"DimDate.DateKey\", \"DateKey\"}}),",
