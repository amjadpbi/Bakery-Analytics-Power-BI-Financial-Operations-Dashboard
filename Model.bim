          {
            "type": "calculated",
            "name": "Days Outstanding",
            "dataType": "int64",
            "isDataTypeInferred": true,
            "expression": [
              "",
              "IF(",
              "    FactPayment[PaymentStatus] IN {\"Pending\", \"Failed\"},",
              "    DATEDIFF(FactPayment[PaymentDate], MAX(FactPayment[PaymentDate]), DAY),",
              "    BLANK()",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "13891fbd-1e45-413a-be04-14fccf24229e",
            "summarizeBy": "sum",
